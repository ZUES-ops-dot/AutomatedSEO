# =============================================================================
# Environment Variables for Qubic SEO Autopilot
# -----------------------------------------------------------------------------
# See ENV_SETUP.md for step-by-step instructions on obtaining every API key.
# Quick start: Copy this file to .env.local and fill in your Anthropic API key.
# -----------------------------------------------------------------------------
# Railway: add variables on the **same service** that runs `next start` (the web
# service). Variables on Postgres/Redis-only services are not visible to the app.
# After changing variables, redeploy so the process reads the new values.
# =============================================================================

NEXT_PUBLIC_APP_NAME=Qubic SEO Autopilot
PRIMARY_SITE_URL=https://qubic.org
DOCS_SITE_URL=https://docs.qubic.org
# Blog posts live on the main site under /blog-detail (not blogs.qubic.org).
BLOG_SITE_URL=https://qubic.org
BLOG_URL_PATH_PREFIX=/blog-detail
QUBIC_RPC_BASE_URL=https://rpc.qubic.org
GDELT_QUERY="Qubic" OR qubic.org

# -----------------------------------------------------------------------------
# AI / LLM -- Anthropic is required (Ollama is not used in Railway deployment)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# -----------------------------------------------------------------------------
# Morningscore -- keywords, onsite crawl, issues, backlinks, dashboard KPIs (optional)
# API: https://api.morningscore.io -- key from Morningscore → Settings → API
# Aliases also accepted: MORNINGSCORE_TOKEN, MS_API_KEY
# -----------------------------------------------------------------------------
MORNINGSCORE_API_KEY=
# Optional: global_domain_identifier from GET /v1/domains (auto-matched from PRIMARY_SITE_URL if unset)
MORNINGSCORE_DOMAIN_ID=

# -----------------------------------------------------------------------------
# Content Sources -- RSS feeds (optional)
# -----------------------------------------------------------------------------
RSS_FEED_URLS=https://qubic.org/blog/feed.xml

# -----------------------------------------------------------------------------
# GitHub -- optional (sync + content publish)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_REPO=qubic/core
GITHUB_CONTENT_REPO=
GITHUB_CONTENT_BRANCH=main
GITHUB_CONTENT_PATH=content/seo

# -----------------------------------------------------------------------------
# Database & Infrastructure
# -----------------------------------------------------------------------------
DATABASE_URL=
# Used for rate limiting (API routes) and optional BullMQ job queue when USE_JOB_QUEUE=true
REDIS_URL=
USE_JOB_QUEUE=false

# -----------------------------------------------------------------------------
# Security -- Required for production/Railway
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
JOB_SECRET=

# -----------------------------------------------------------------------------
# Sentry -- Error tracking (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Data storage location override (optional)
# -----------------------------------------------------------------------------
SEO_DATA_DIR=

# -----------------------------------------------------------------------------
# Multi-tenant mode -- Reserved for future use
# -----------------------------------------------------------------------------
MULTI_TENANT=false

# -----------------------------------------------------------------------------
# Reserved for future use -- not read by application code today
# -----------------------------------------------------------------------------
COINGECKO_API_KEY=
